---
import { getCollection } from 'astro:content';
import BaseHead from '../astro/components/BaseHead.astro';
import Footer from '../astro/components/Footer.astro';
import Header from '../astro/components/Header.astro';
import PostCard from '../astro/components/PostCard.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 10);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-16">
      <section class="mb-16">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900 dark:text-slate-100 mb-4">
          Hello, World
        </h1>
        <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
          관심 있는 기술에 대해 공유하고 일상의 이야기를 기록하고 있습니다.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-slate-900 dark:text-slate-100 mb-6">최근 글</h2>
        <ul class="space-y-8">
          {posts.map((post) => (
            <li>
              <PostCard post={post} />
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
