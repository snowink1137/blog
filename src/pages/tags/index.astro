---
import { getCollection } from 'astro:content';
import BaseHead from '../../astro/components/BaseHead.astro';
import Footer from '../../astro/components/Footer.astro';
import Header from '../../astro/components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = await getCollection('blog');
const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}
const tags = Array.from(tagCounts.entries()).sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0]),
);
---

<!doctype html>
<html lang="ko">
  <head>
    <BaseHead title={`Tags | ${SITE_TITLE}`} description="태그 목록" />
  </head>
  <body>
    <Header />
    <main class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-100 mb-2">Tags</h1>
        <p class="text-slate-600 dark:text-slate-400">{tags.length}개의 태그</p>
      </header>
      <div class="flex flex-wrap gap-2">
        {tags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}/`}
            class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-700 transition-colors"
          >
            <span>{tag}</span>
            <span class="text-xs text-slate-500 dark:text-slate-500">{count}</span>
          </a>
        ))}
      </div>
    </main>
    <Footer />
  </body>
</html>
